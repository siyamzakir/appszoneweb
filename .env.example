# ─── Database (Prisma + SQLite) ───────────────────────────────────────────────
# For production swap to: postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./appszone.db"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-char-random-secret-here   # run: openssl rand -base64 32

# ─── OAuth Providers ──────────────────────────────────────────────────────────
# Google → https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub → https://github.com/settings/apps
GITHUB_ID=
GITHUB_SECRET=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret (from Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# Create these in Stripe Dashboard → Products → Prices
# Starter plan is free, so these are optional (can be left empty)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=

STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...
